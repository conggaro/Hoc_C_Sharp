{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-api-debug",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/API/API.csproj",
        "-c",
        "Debug",
        "-r",
        "win-x64",
        "--no-self-contained"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
